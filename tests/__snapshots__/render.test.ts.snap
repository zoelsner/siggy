// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderSignature > matches snapshot for { id: 'bold', name: 'Bold', description: 'Massive split-color name as hero.', headline: 'Maximum typographic impact.', supportsImage: false, render: [Function bold] } 1`] = `"<div data-siggy-profile="gmail_web" data-siggy-template="bold"><table role="presentation" cellPadding="0" cellSpacing="0" style="border-collapse:collapse;font-family:Arial, &#x27;Segoe UI&#x27;, &#x27;Helvetica Neue&#x27;, Helvetica, sans-serif;color:#0f172a;width:100%"><tbody><tr><td colSpan="2" style="padding-bottom:4px"><div style="font-size:38px;font-weight:900;letter-spacing:-0.06em;line-height:0.84;font-family:&#x27;DM Sans&#x27;, sans-serif"><span style="color:#0f172a">SARAH</span><br/><span style="color:#4f46e5">CHEN</span></div><div style="height:3px;background:#4f46e5;width:100%;margin:5px 0 0;border-radius:2px"></div></td></tr><tr><td style="vertical-align:top;padding-top:8px;padding-right:24px"><div style="font-size:12px;font-weight:800;letter-spacing:0.06em;color:#0f172a">HEAD OF DESIGN</div><div style="font-size:13px;color:#475569;margin-top:2px">Meridian Studio</div></td><td style="vertical-align:top;padding-top:8px;border-left:1px solid #e2e8f0;padding-left:24px"><table cellPadding="0" cellSpacing="0" style="border-collapse:collapse;font-family:Arial, &#x27;Segoe UI&#x27;, &#x27;Helvetica Neue&#x27;, Helvetica, sans-serif;font-size:13px;color:#475569"><tbody><tr><td style="padding-right:8px;color:#94a3b8;font-size:13px">☏</td><td style="padding-bottom:4px">+1 (415) 555-0142</td></tr><tr><td style="padding-right:8px;color:#94a3b8;font-size:13px">✉</td><td style="padding-bottom:4px"><a href="mailto:sarah@meridian.design" style="color:#4f46e5;text-decoration:none">sarah@meridian.design</a></td></tr><tr><td style="padding-right:8px;color:#94a3b8;font-size:13px">⊕</td><td><a href="https://meridian.design" style="color:#4f46e5;text-decoration:none">meridian.design</a></td></tr></tbody></table></td></tr><tr><td colSpan="2"><div style="margin-top:10px;font-size:12px"><a href="https://siggy.app" style="color:#64748b;text-decoration:none;font-weight:600">Made with Siggy</a></div></td></tr></tbody></table></div>"`;

exports[`renderSignature > matches snapshot for { id: 'card', name: 'Card', description: 'Visual anchor with a tinted headshot panel.', headline: 'Structured and memorable.', supportsImage: true, render: [Function card] } 1`] = `"<link rel="preload" as="image" href="https://example.com/avatar.jpg"/><div data-siggy-profile="gmail_web" data-siggy-template="card"><table role="presentation" cellPadding="0" cellSpacing="0" style="border-collapse:collapse;font-family:Arial, &#x27;Segoe UI&#x27;, &#x27;Helvetica Neue&#x27;, Helvetica, sans-serif;color:#0f172a"><tbody><tr><td style="background:#f4f4f8;border-radius:12px;padding:34px 28px;vertical-align:middle;text-align:center"><img alt="Sarah Chen headshot" src="https://example.com/avatar.jpg" width="94" height="94" style="border-radius:14px;display:block"/></td><td style="padding:20px 0 20px 28px;vertical-align:top;min-width:360px"><div style="font-size:24px;font-weight:800;letter-spacing:-0.02em;color:#4f46e5;font-family:&#x27;DM Sans&#x27;, sans-serif">Sarah Chen</div><div style="font-size:14px;color:#0f172a;margin-top:2px">Head of Design <span style="color:#94a3b8">·</span> Meridian Studio</div><div style="height:1px;background:#e2e8f0;margin:14px 0;width:100%"></div><div style="font-size:13px;color:#0f172a;line-height:20px"><a href="mailto:sarah@meridian.design" style="color:#4f46e5;text-decoration:none">sarah@meridian.design</a><span style="color:#94a3b8;margin:0 10px">|</span> +1 (415) 555-0142<br/><a href="https://meridian.design" style="color:#4f46e5;text-decoration:none">meridian.design</a></div><div style="margin-top:10px;font-size:12px"><a href="https://siggy.app" style="color:#64748b;text-decoration:none;font-weight:600">Made with Siggy</a></div></td></tr></tbody></table></div>"`;

exports[`renderSignature > matches snapshot for { id: 'clean', name: 'Minimal', description: 'Pure text, accent name, zero chrome.', headline: 'Quiet and portable.', supportsImage: false, render: [Function clean] } 1`] = `"<div data-siggy-profile="gmail_web" data-siggy-template="clean"><table role="presentation" cellPadding="0" cellSpacing="0" style="border-collapse:collapse;font-family:Arial, &#x27;Segoe UI&#x27;, &#x27;Helvetica Neue&#x27;, Helvetica, sans-serif;color:#0f172a"><tbody><tr><td><div style="font-size:20px;font-weight:800;color:#4f46e5;font-family:&#x27;DM Sans&#x27;, sans-serif">Sarah Chen</div><div style="font-size:14px;color:#0f172a;margin-top:2px">Head of Design, Meridian Studio</div><div style="margin-top:16px;font-size:13px;color:#0f172a;line-height:1.7"><a href="mailto:sarah@meridian.design" style="color:#0f172a;text-decoration:none">sarah@meridian.design</a><span style="color:#d1d5db;margin:0 8px">·</span><span style="color:#0f172a">+1 (415) 555-0142</span><span style="color:#d1d5db;margin:0 8px">·</span><a href="https://meridian.design" style="color:#0f172a;text-decoration:none">meridian.design</a></div><div style="margin-top:10px;font-size:12px"><a href="https://siggy.app" style="color:#64748b;text-decoration:none;font-weight:600">Made with Siggy</a></div></td></tr></tbody></table></div>"`;


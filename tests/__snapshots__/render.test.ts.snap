/tr><tr><td style="padding-right:8px;color:#94a3b8;font-size:13px">⊕</td><td><a href="https://meridian.design" style="color:#4f46e5;text-decoration:none">meridian.design</a></td></tr></tbody></table></td></tr></tbody></table><div style="margin-top:10px;font-size:12px"><a href="https://siggy.app" style="color:#64748b;text-decoration:none;font-weight:600">Made with Siggy</a></div></td></tr></tbody></table></div>"`;
